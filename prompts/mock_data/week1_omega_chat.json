    { "message_id": "om_019", "sender": "ou_me_lzc", "create_time": "2026-04-22T16:02:00+08:00", "msg_type": "text", "content": "收到。" },

    { "message_id": "om_020", "sender": "ou_pm_lin", "create_time": "2026-04-23T09:30:00+08:00", "msg_type": "text", "content": "刚刚收到客户群消息，转发一下：客户 X 反馈说默认进来希望看上周数据，不是当天的。这个需求我们消化一下。" },
