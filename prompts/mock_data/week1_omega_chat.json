    { "message_id": "om_015", "sender": "ou_chen_xb", "create_time": "2026-04-22T09:52:00+08:00", "msg_type": "text", "content": "好的，我开始集成。这周五前给到测试环境。" },
    { "message_id": "om_016", "sender": "ou_wang_qa", "create_time": "2026-04-22T14:20:00+08:00", "msg_type": "text", "content": "提醒一下后端同学：测试环境的 dt 字段存的是上海时间不是 UTC，之前 Q1 那次就因为这个查错过一周数据。建议 query 时显式 +8:00。" },
